@inject IGitReadOperations Git

<div class="sidebar">
    @if (Repo is not null)
    {
        <SidebarSection Title="Local Branches">
            <BranchTreeView Nodes="_localTree" Open="_open" />
        </SidebarSection>
        <SidebarSection Title="Remotes">
            @foreach (var r in _remotes)
            {
                <div class="remote">@r.Name</div>
                <BranchTreeView Nodes="@RemoteTree(r)" Open="_open" />
            }
            @if (_remotes.Count == 0)
            {
                <div class="branch-empty">No remotes</div>
            }
        </SidebarSection>
        <SidebarSection Title="Tags">
            @if (_tags.Count == 0)
            {
                <div class="branch-empty">No tags</div>
            }
            else
            {
                @foreach (var t in _tags)
                {
                    <div class="ref-row">@t.Name</div>
                }
            }
        </SidebarSection>
        <SidebarSection Title="Stashes">
            @if (_stashes.Count == 0)
            {
                <div class="branch-empty">No stashes</div>
            }
            else
            {
                @foreach (var s in _stashes)
                {
                    <div class="ref-row stash-row" title="@s.Message">
                        <span class="stash-idx">stash@@@s.Index</span>
                        <span class="stash-msg">@s.Message</span>
                    </div>
                }
            }
        </SidebarSection>
    }
    else
    {
        <div class="empty">No repository selected</div>
    }
</div>

@code {
    [Parameter] public RepoLocation? Repo { get; set; }

    private IReadOnlyList<Branch> _branches = Array.Empty<Branch>();
    private IReadOnlyList<Tag>    _tags = Array.Empty<Tag>();
    private IReadOnlyList<Remote> _remotes = Array.Empty<Remote>();
    private IReadOnlyList<Stash>  _stashes = Array.Empty<Stash>();
    private List<BranchTreeNode> _localTree = new();
    private readonly Dictionary<string, List<BranchTreeNode>> _remoteTreeCache = new();
    private HashSet<string> _open = new();

    private List<BranchTreeNode> RemoteTree(Remote remote)
    {
        if (!_remoteTreeCache.TryGetValue(remote.Name, out var tree))
        {
            tree = BranchTree.Build(remote.Branches);
            _remoteTreeCache[remote.Name] = tree;
        }
        return tree;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Repo is null)
        {
            _branches = Array.Empty<Branch>();
            _tags = Array.Empty<Tag>();
            _remotes = Array.Empty<Remote>();
            _stashes = Array.Empty<Stash>();
            _localTree = new();
            _remoteTreeCache.Clear();
            _open.Clear();
            return;
        }
        _branches = await Git.GetBranchesAsync(Repo, default);
        _tags     = await Git.GetTagsAsync(Repo, default);
        _remotes  = await Git.GetRemotesAsync(Repo, default);
        _stashes  = await Git.GetStashesAsync(Repo, default);

        _localTree = BranchTree.Build(_branches.Where(b => !b.IsRemote));
        _remoteTreeCache.Clear();

        // Pre-expand all folder paths so the tree is visible by default.
        _open = new HashSet<string>(BranchTree.AllFolderPaths(_localTree));
        foreach (var r in _remotes)
        {
            foreach (var path in BranchTree.AllFolderPaths(RemoteTree(r)))
                _open.Add(path);
        }
    }
}
