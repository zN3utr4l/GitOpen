@inject Photino.NET.PhotinoWindow Window

<div class="titlebar"
     onpointerdown="gitOpen.startDrag(event)"
     ondblclick="gitOpen.doubleClickMaximize(event)">
    <div class="brand">
        <span class="logo-dot"></span>
        <span class="brand-name">GitOpen</span>
    </div>

    <div class="tabs">
        @foreach (var ws in _items)
        {
            <button class="tab app-no-drag @(ws.Location.Id == Active ? "active" : "")"
                    @onclick="() => OnActivate.InvokeAsync(ws.Location.Id)">
                <span class="tab-name">@ws.Location.DisplayName</span>
                <span class="tab-close"
                      @onclick:stopPropagation="true"
                      @onclick="() => OnClose.InvokeAsync(ws.Location.Id)"
                      title="Close tab">×</span>
            </button>
        }
        <button class="tab-add app-no-drag" @onclick="OnOpenRepo" title="Open repository">+</button>
    </div>

    <div class="spacer"></div>

    <div class="window-controls">
        <button class="wc wc-min app-no-drag" @onclick="Minimize" title="Minimize">
            <svg viewBox="0 0 12 12" width="12" height="12"><line x1="2" y1="6" x2="10" y2="6" stroke="currentColor" stroke-width="1"/></svg>
        </button>
        <button class="wc wc-max app-no-drag" @onclick="ToggleMaximize" title="@(_isMax ? "Restore" : "Maximize")">
            @if (_isMax)
            {
                <svg viewBox="0 0 12 12" width="12" height="12">
                    <rect x="2.5" y="3.5" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1"/>
                    <path d="M4 3 V2 H10 V8 H8.5" fill="none" stroke="currentColor" stroke-width="1"/>
                </svg>
            }
            else
            {
                <svg viewBox="0 0 12 12" width="12" height="12"><rect x="2.5" y="2.5" width="7" height="7" fill="none" stroke="currentColor" stroke-width="1"/></svg>
            }
        </button>
        <button class="wc wc-close app-no-drag" @onclick="Close" title="Close">
            <svg viewBox="0 0 12 12" width="12" height="12">
                <line x1="3" y1="3" x2="9" y2="9" stroke="currentColor" stroke-width="1"/>
                <line x1="9" y1="3" x2="3" y2="9" stroke="currentColor" stroke-width="1"/>
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter] public RepoId Active { get; set; }
    [Parameter] public EventCallback<RepoId> OnActivate { get; set; }
    [Parameter] public EventCallback<RepoId> OnClose { get; set; }
    [Parameter] public EventCallback OnOpenRepo { get; set; }

    [Inject] private IWorkspaceManager Workspaces { get; set; } = default!;

    private IReadOnlyList<Workspace> _items = Array.Empty<Workspace>();
    private bool _isMax;

    protected override void OnInitialized()
    {
        Refresh();
        Workspaces.Opened    += _ => Reload();
        Workspaces.Closed    += _ => Reload();
        Workspaces.Reordered += _ => Reload();
    }

    private void Reload()
    {
        Refresh();
        InvokeAsync(StateHasChanged);
    }

    private void Refresh() => _items = Workspaces.All;

    private void Minimize() => Window.SetMinimized(true);

    private void ToggleMaximize()
    {
        _isMax = !_isMax;
        Window.SetMaximized(_isMax);
    }

    private void Close() => Window.Close();
}
