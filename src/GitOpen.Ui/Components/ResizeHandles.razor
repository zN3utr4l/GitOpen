@* Invisible edge zones that initiate window resize via the host's
   custom-scheme handler. The JS gitOpen.startResize listens for
   pointermove/pointerup at document level so resize keeps working
   when the cursor leaves a handle. *@

<div class="rh rh-n"  onpointerdown="gitOpen.startResize('n', event)"></div>
<div class="rh rh-s"  onpointerdown="gitOpen.startResize('s', event)"></div>
<div class="rh rh-e"  onpointerdown="gitOpen.startResize('e', event)"></div>
<div class="rh rh-w"  onpointerdown="gitOpen.startResize('w', event)"></div>
<div class="rh rh-ne" onpointerdown="gitOpen.startResize('ne', event)"></div>
<div class="rh rh-nw" onpointerdown="gitOpen.startResize('nw', event)"></div>
<div class="rh rh-se" onpointerdown="gitOpen.startResize('se', event)"></div>
<div class="rh rh-sw" onpointerdown="gitOpen.startResize('sw', event)"></div>
