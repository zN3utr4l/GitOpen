@if (Nodes.Count == 0)
{
    <div class="branch-empty">No branches</div>
}
else
{
    <ul class="branch-tree" style="--depth: @Depth">
        @foreach (var node in Nodes)
        {
            <li>
                @if (node.Children.Count == 0)
                {
                    <div class="branch-row @(node.Branch?.IsCurrent == true ? "current" : "")"
                         title="@node.Branch?.FullName"
                         style="padding-left: calc(@(Depth) * 14px + 18px)">
                        @if (node.Branch?.IsCurrent == true)
                        {
                            <span class="check">✓</span>
                        }
                        else
                        {
                            <span class="check-spacer"></span>
                        }
                        <span class="branch-name">@node.Name</span>
                    </div>
                }
                else
                {
                    <div class="folder-row"
                         @onclick="() => Toggle(node.FullPath)"
                         style="padding-left: calc(@(Depth) * 14px + 6px)">
                        <span class="chev">@(IsOpen(node.FullPath) ? "▾" : "▸")</span>
                        <span class="folder-name">@node.Name</span>
                    </div>
                    @if (IsOpen(node.FullPath))
                    {
                        <BranchTreeView Nodes="node.Children" Open="Open" Depth="Depth + 1" />
                    }
                }
            </li>
        }
    </ul>
}

@code {
    [Parameter] public IReadOnlyList<BranchTreeNode> Nodes { get; set; } = Array.Empty<BranchTreeNode>();
    [Parameter] public HashSet<string> Open { get; set; } = new();
    [Parameter] public int Depth { get; set; }

    private bool IsOpen(string path) => Open.Contains(path);

    private void Toggle(string path)
    {
        if (!Open.Remove(path)) Open.Add(path);
        StateHasChanged();
    }
}
