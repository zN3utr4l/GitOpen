<div class="row @(Selected ? "selected" : "")" @onclick="() => OnSelect.InvokeAsync(Node.Commit.Sha)">
    <div class="lanes">
        <svg width="@SvgWidth" height="@RowHeight" shape-rendering="geometricPrecision"
             xmlns="http://www.w3.org/2000/svg">
            <g stroke-width="1.6" stroke-linecap="round" fill="none">
                @foreach (var seg in Node.TopSegments)
                {
                    @if (seg.FromLane == seg.ToLane)
                    {
                        <line x1="@LaneX(seg.FromLane)" y1="0"
                              x2="@LaneX(seg.ToLane)" y2="@HalfHeight"
                              stroke="@Color(seg.Color)" />
                    }
                    else
                    {
                        <path d="@TopCurve(seg.FromLane, seg.ToLane)"
                              stroke="@Color(seg.Color)" />
                    }
                }
                @foreach (var seg in Node.BottomSegments)
                {
                    @if (seg.FromLane == seg.ToLane)
                    {
                        <line x1="@LaneX(seg.FromLane)" y1="@HalfHeight"
                              x2="@LaneX(seg.ToLane)" y2="@RowHeight"
                              stroke="@Color(seg.Color)" />
                    }
                    else
                    {
                        <path d="@BottomCurve(seg.FromLane, seg.ToLane)"
                              stroke="@Color(seg.Color)" />
                    }
                }
            </g>
            <circle cx="@LaneX(Node.Lane)" cy="@HalfHeight" r="4"
                    fill="@Color(Node.Color)" />
        </svg>
    </div>
    <div class="sha">@Node.Commit.Sha.Short()</div>
    <div class="message">
        @foreach (var r in Refs)
        {
            <RefPill Name="@r.name" IsRemote="@r.remote" IsTag="@r.tag" IsCurrent="@r.current" />
        }
        <span class="message-text">@Node.Commit.Summary</span>
    </div>
    <div class="author">@Node.Commit.Author.Name</div>
    <div class="when">@Node.Commit.Author.When.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</div>
</div>

@code {
    [Parameter] public CommitNode Node { get; set; } = default!;
    [Parameter] public int MaxLane { get; set; }
    [Parameter] public bool Selected { get; set; }
    [Parameter] public EventCallback<CommitSha> OnSelect { get; set; }
    [Parameter] public IReadOnlyList<(string name, bool remote, bool tag, bool current)> Refs { get; set; }
        = Array.Empty<(string, bool, bool, bool)>();

    private const int LaneSpacing = 16;
    private const int LanePad = 12;
    private const int RowHeight = 26;
    private const int HalfHeight = 13;

    private int SvgWidth => LanePad * 2 + LaneSpacing * (MaxLane + 1);

    private int LaneX(int lane) => LanePad + lane * LaneSpacing;

    // Lane palette pulled from CSS custom properties for consistency with the rest of the UI.
    private static readonly string[] Palette = new[]
    {
        "var(--lane-1)", "var(--lane-2)", "var(--lane-3)", "var(--lane-4)",
        "var(--lane-5)", "var(--lane-6)", "var(--lane-7)", "var(--lane-8)"
    };

    private string Color(int lane) => Palette[Math.Abs(lane) % Palette.Length];

    // Curved top segment: from (fromLane, y=0) to (toLane, y=HalfHeight)
    // Smoothly transitions using a cubic Bezier.
    private string TopCurve(int fromLane, int toLane)
    {
        var x1 = LaneX(fromLane);
        var x2 = LaneX(toLane);
        var midY = HalfHeight / 2.0;
        return $"M {x1} 0 C {x1} {midY}, {x2} {midY}, {x2} {HalfHeight}";
    }

    // Curved bottom segment: from (fromLane, y=HalfHeight) to (toLane, y=RowHeight)
    private string BottomCurve(int fromLane, int toLane)
    {
        var x1 = LaneX(fromLane);
        var x2 = LaneX(toLane);
        var midY = HalfHeight + (RowHeight - HalfHeight) / 2.0;
        return $"M {x1} {HalfHeight} C {x1} {midY}, {x2} {midY}, {x2} {RowHeight}";
    }
}
